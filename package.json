{
  "name": "ayursutra",
  "version": "1.0.0",
  "description": "Government-standard Ayurveda management platform",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && npm run dev",
    "client:dev": "cd client && npm start",
    "mobile:dev": "cd mobile && npm start",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install && cd ../mobile && npm install",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "keywords": ["ayurveda", "healthcare", "government", "ndhm", "ayush"],
  "author": "AyurSutra Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}